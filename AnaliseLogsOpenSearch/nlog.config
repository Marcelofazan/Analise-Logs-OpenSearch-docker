<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://nlog-project.org"
      xmlns:xsi="http://w3.org"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="${currentdir}/logs/internal-nlog.txt">

	<extensions>
		<add assembly="NLog.Web.AspNetCore"/>
		<add assembly="NLog.DiagnosticSource"/>
		<add assembly="NLog.Targets.OpenSearch"/>
	</extensions>

	<variable name="appName" value="analiselogsopensearch" />

	<targets async="false">
		<!-- Target do OpenSearch Corrigido para Envio Estruturado (JSON nativo) -->
		<target xsi:type="OpenSearch"
				name="opensearch"
				uri="http://opensearch:9200"
				index="${var:appName}-${shortdate}">

			<!-- O JsonLayout agora define o corpo raiz do documento enviado ao OpenSearch -->
			<layout xsi:type="JsonLayout" includeAllProperties="true">
				<!-- Propriedades Básicas de Log -->
				<attribute name="timestamp" layout="${date:format=yyyy-MM-ddTHH\:mm\:ss.fffK}" />
				<attribute name="level" layout="${level}" />
				<attribute name="message" layout="${message}" />
				<attribute name="logger" layout="${logger}" />
				<attribute name="exception" layout="${exception:format=toString}" />
				
				<!-- Identificadores de Rastreamento Nativos (W3C) -->
				<attribute name="traceId" layout="${activity:traceId}" />
				<attribute name="spanId" layout="${activity:spanId}" />

				<!-- Metadados de Auditoria Web Estáveis e Homologados -->
				<attribute name="applicationName" layout="${var:appName}" />
				<attribute name="requestPath" layout="${aspnet-request-url:IncludeQueryString=true}" />
				<attribute name="statusCode" layout="${aspnet-response-statuscode}" />
				<attribute name="userAgent" layout="${aspnet-request-useragent}" />
				<attribute name="host" layout="${aspnet-request-host}" />
				<attribute name="method" layout="${aspnet-request-method}" />
			</layout>
		</target>

		<!-- TARGET LOCAL: Cópia síncrona de segurança dentro do sistema -->
		<target xsi:type="File" 
				name="arquivoLocal" 
				fileName="${currentdir}/logs/app-logs-${shortdate}.json">
			<layout xsi:type="JsonLayout" includeAllProperties="true">
				<attribute name="timestamp" layout="${date:format=yyyy-MM-ddTHH\:mm\:ss.fffK}" />
				<attribute name="level" layout="${level}" />
				<attribute name="message" layout="${message}" />
				<attribute name="traceId" layout="${activity:traceId}" />
				<attribute name="requestPath" layout="${aspnet-request-url:IncludeQueryString=true}" />
				<attribute name="statusCode" layout="${aspnet-response-statuscode}" />
			</layout>
		</target>
	</targets>

	<rules>
		<!-- Filtros de descarte para limpar o ruído excessivo de logs do framework Kestrel -->
		<logger name="Microsoft.AspNetCore.StaticFiles.*" maxlevel="Info" final="true" />
		<logger name="Microsoft.AspNetCore.Hosting.Diagnostics" maxlevel="Info" final="true" />

		<!-- Direciona todas as mensagens do sistema para os alvos ativos -->
		<logger name="*" minlevel="Info" writeTo="opensearch,arquivoLocal" />
	</rules>
</nlog>